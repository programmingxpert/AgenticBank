# ============================================
# Autonomous Banking Agents — Configuration
# ============================================
# Copy this file to .env and fill in your values

# === Deepseek API Configuration ===
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro

# === Server Configuration ===
PORT=3000
NODE_ENV=development

# === Agent Configuration ===
# Transfers above this amount (USD) require human approval
HUMAN_APPROVAL_THRESHOLD_TRANSFER=10000
# Trades above this amount (USD) require human approval
HUMAN_APPROVAL_THRESHOLD_TRADE=5000
# LLM temperature for agent responses (lower = more deterministic)
AGENT_TEMPERATURE=0.3
# Max tokens per agent response
AGENT_MAX_TOKENS=2048

# === Security ===
SESSION_SECRET=change_this_to_a_random_string
